---
---
<footer class="site-footer">
  <!-- CTA band (matches JCU "Become a Member" green band) -->
  <div class="footer-cta">
    <div class="container footer-cta-inner">
      <p class="footer-cta-title">Jordan Credit Union — Here to Help</p>
      <p class="footer-cta-text">Serving members in Davis, Morgan, Salt Lake, Tooele, Utah, and Weber Counties since 1950.</p>
      <a href="https://jordan-cu.org/about-us/" class="btn btn-primary">Learn More</a>
    </div>
  </div>

  <!-- Main footer -->
  <div class="footer-main">
    <div class="container footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="https://jordan-cu.org/" class="footer-logo" aria-label="Jordan Credit Union — Home">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="20" cy="20" r="18" stroke="#2d8a4e" stroke-width="2" fill="none"/>
            <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Montserrat,sans-serif" font-weight="700" font-size="7" fill="#2d8a4e">JCU</text>
          </svg>
          <div>
            <span class="footer-logo-name">Jordan</span>
            <span class="footer-logo-sub">Credit Union</span>
          </div>
        </a>
        <div class="footer-social">
          <a href="https://www.facebook.com/jordancreditunion" aria-label="JCU on Facebook" rel="noopener noreferrer" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/jordancreditunion/" aria-label="JCU on Instagram" rel="noopener noreferrer" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
        <address class="footer-address">
          <p>801-566-4175</p>
          <p>Routing: 324377723</p>
          <p>P.O. Box 1883, Sandy, UT 84091</p>
        </address>
      </div>

      <!-- Link columns -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h3 class="footer-col-heading">Savings</h3>
          <ul>
            <li><a href="https://jordan-cu.org/accounts/savings-accounts/">Savings Accounts</a></li>
            <li><a href="https://jordan-cu.org/accounts/checking-accounts/">Checking Accounts</a></li>
            <li><a href="https://jordan-cu.org/accounts/certificate-accounts/">Certificate Accounts</a></li>
            <li><a href="https://jordan-cu.org/accounts/high-yield-money-market/">High Yield Money Market</a></li>
            <li><a href="https://jordan-cu.org/accounts/">Accounts</a></li>
            <li><a href="https://jordan-cu.org/rates/">Rates</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-heading">Loans</h3>
          <ul>
            <li><a href="https://jordan-cu.org/loans/auto-loans/">Auto Loans</a></li>
            <li><a href="https://jordan-cu.org/loans/visa-credit-cards/">VISA Credit Cards</a></li>
            <li><a href="https://jordan-cu.org/loans/personal-loans/">Personal Loans</a></li>
            <li><a href="https://jordan-cu.org/loans/mortgages/">Mortgage</a></li>
            <li><a href="https://jordan-cu.org/loans/home-equity/">Home Equity</a></li>
            <li><a href="https://jordan-cu.org/business/business-lending/">Business Lending</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-heading">Online Services</h3>
          <ul>
            <li><a href="https://jordan-cu.org/online-services/online-banking/">Online Banking</a></li>
            <li><a href="https://jordan-cu.org/online-services/mobile-app/">Mobile App</a></li>
            <li><a href="https://jordan-cu.org/online-services/bill-pay/">Bill Pay</a></li>
            <li><a href="https://jordan-cu.org/online-services/loan-payments/">Loan Payments</a></li>
            <li><a href="https://jordan-cu.org/online-services/visa-help/">VISA Help</a></li>
            <li><a href="https://jordan-cu.org/online-services/order-checks/">Order Checks</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-heading">About Us</h3>
          <ul>
            <li><a href="https://jordan-cu.org/about-us/">About JCU</a></li>
            <li><a href="https://jordan-cu.org/about-us/contact-us/">Contact Us</a></li>
            <li><a href="https://jordan-cu.org/about-us/careers/">Careers</a></li>
            <li><a href="https://jordan-cu.org/about-us/membership/">Membership</a></li>
            <li><a href="https://jordan-cu.org/about-us/policies-and-disclosure/">Policies & Disclosure</a></li>
            <li><a href="/medicare/" class="footer-link-highlight">Medicare Benefits</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <div class="footer-badges">
          <img src="https://jordan-cu.org/wp-content/themes/jordancu/images/ncua.png" alt="NCUA insured" width="60" height="40" loading="lazy" onerror="this.style.display='none'">
          <img src="https://jordan-cu.org/wp-content/themes/jordancu/images/equal-housing.png" alt="Equal Housing Lender" width="40" height="40" loading="lazy" onerror="this.style.display='none'">
        </div>
        <p class="footer-legal">
          © {new Date().getFullYear()} Jordan Credit Union. All rights reserved.
          NCUA insured. Equal Housing Opportunity.
          Federally chartered credit union.
        </p>
        <a href="https://jordan-cu.org/online-services/online-banking/" class="btn btn-primary btn-sm">Login</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* CTA band */
  .footer-cta { background: var(--jcu-green); padding: var(--space-lg) 0; text-align: center; }
  .footer-cta-inner { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  .footer-cta-title { font-family: var(--font-script); font-size: 2rem; color: var(--jcu-white); }
  .footer-cta-text { color: rgba(255,255,255,0.85); font-size: 0.95rem; max-width: 520px; }

  /* Main footer */
  .footer-main { background: var(--jcu-white); padding: var(--space-xl) 0 0; }
  .footer-grid { display: grid; grid-template-columns: 240px 1fr; gap: var(--space-xl); }

  /* Brand */
  .footer-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; margin-bottom: 1rem; }
  .footer-logo-name { display: block; font-size: 1.2rem; font-weight: 800; color: var(--jcu-green); }
  .footer-logo-sub { display: block; font-size: 0.6rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--jcu-green-mid); }
  .footer-social { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
  .footer-social a { color: var(--jcu-gray-text); transition: color 0.2s; }
  .footer-social a:hover { color: var(--jcu-green-mid); }
  .footer-address { font-style: normal; font-size: 0.85rem; color: var(--jcu-gray-text); line-height: 1.8; }

  /* Nav columns */
  .footer-nav { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
  .footer-col-heading { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--jcu-dark); margin-bottom: 0.75rem; }
  .footer-col ul { list-style: none; }
  .footer-col li + li { margin-top: 0.4rem; }
  .footer-col a { font-size: 0.85rem; color: var(--jcu-gray-text); }
  .footer-col a:hover { color: var(--jcu-green-mid); }
  .footer-link-highlight { color: var(--jcu-green-mid) !important; font-weight: 600; }

  /* Bottom bar */
  .footer-bottom { background: var(--jcu-green); margin-top: var(--space-lg); padding: 1rem 0; }
  .footer-bottom-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .footer-badges { display: flex; align-items: center; gap: 0.75rem; }
  .footer-legal { font-size: 0.75rem; color: rgba(255,255,255,0.75); flex: 1; min-width: 200px; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .footer-nav { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
