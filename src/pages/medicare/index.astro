---
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── Contact & advisor info ────────────────────────────────────────────────────
const CHERLYNN_PHONE     = '801-349-5059';
const CHERLYNN_PHONE_TEL = '+18013495059';
const CHERLYNN_EMAIL     = 'pcherlynn@gmail.com';
const CHERLYNN_BIO       = 'Cherlynn Pearson has spent more than 35 years helping Utah families make confident healthcare decisions. As a licensed insurance agent with A&B Health Advocates, she specializes in Medicare and takes the time to understand each person\'s unique situation — your doctors, medications, and budget — so you get coverage that truly fits your life.';
const CHERLYNN_HEADSHOT  = '/images/cherlynn-pearson.jpg';

// ── Form endpoint ─────────────────────────────────────────────────────────────
const FORM_ENDPOINT      = 'https://formspree.io/f/xjgdqozv';
// ─────────────────────────────────────────────────────────────────────────────
---

<BaseLayout
  title="Medicare Help for Members | Jordan Credit Union"
  description="Free Medicare guidance for Jordan Credit Union members 65 and older. Cherlynn Pearson, your dedicated JCU Medicare advisor, helps you understand your options and enroll with confidence — at no cost, no obligation."
  ogTitle="Medicare Help for Members | Jordan Credit Union"
  ogDescription="Free Medicare guidance from Cherlynn Pearson, Jordan Credit Union's dedicated Medicare advisor. No cost, no obligation for JCU members."
>

  <!-- ══════════════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-inner container">
      <div class="hero-content">
        <span class="hero-tag">A Free Member Benefit</span>
        <h1 id="hero-heading" class="hero-title">
          Medicare made simple —<br class="br-lg"> a free service for<br class="br-lg"> Jordan Credit Union members.
        </h1>
        <p class="hero-sub">
          Turning 65 or already on Medicare? Cherlynn Pearson, your Jordan Credit Union Medicare
          advisor, will help you understand your options and choose the right plan —
          at no cost and no obligation.
        </p>
        <div class="hero-actions">
          <a href="#consultation" class="btn btn-primary hero-btn">
            Schedule a Free Consultation
          </a>
          <a href={`tel:${CHERLYNN_PHONE_TEL}`} class="btn btn-white hero-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.6a16 16 0 0 0 6.08 6.08l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Cherlynn
          </a>
        </div>
      </div>
      <div class="hero-photo" aria-hidden="true">
        <div class="hero-photo-frame">
          <img
            src={CHERLYNN_HEADSHOT}
            alt="Cherlynn Pearson, Jordan Credit Union Medicare Advisor"
            width="340"
            height="400"
            loading="eager"
            class="advisor-photo"
          />
          <div class="hero-photo-badge">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Licensed Medicare Advisor</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       2. WHY THIS IS A MEMBER BENEFIT
  ══════════════════════════════════════════════════════════ -->
  <section class="benefits bg-light section-pad" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="section-header centered">
        <span class="section-eyebrow">Your membership advantage</span>
        <h2 id="benefits-heading" class="section-title">Why JCU members turn to Cherlynn</h2>
        <p class="section-subtitle">
          Medicare is complicated. You deserve a local expert who puts your needs first —
          not a 1-800 number reading from a script.
        </p>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="benefit-title">No cost. No obligation.</h3>
          <p>This service is completely free for JCU members and their families. No pressure, ever.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="benefit-title">A local, trusted source.</h3>
          <p>Work with someone in your community, not a national call center. Cherlynn knows Utah.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="benefit-title">Personalized to you.</h3>
          <p>Recommendations based on your doctors, prescriptions, and budget — not a one-size-fits-all plan.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="benefit-title">Help from start to finish.</h3>
          <p>Cherlynn coaches you through enrollment so you're covered correctly — and stays available for questions later.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       3. MEET YOUR ADVISOR
  ══════════════════════════════════════════════════════════ -->
  <section class="advisor section-pad bg-white" aria-labelledby="advisor-heading">
    <div class="container">
      <div class="section-header centered">
        <span class="section-eyebrow">Your dedicated advisor</span>
        <h2 id="advisor-heading" class="section-title">Meet Cherlynn Pearson</h2>
      </div>
      <div class="advisor-card">
        <div class="advisor-photo-wrap">
          <img
            src={CHERLYNN_HEADSHOT}
            alt="Cherlynn Pearson, Jordan Credit Union Medicare Advisor"
            width="280"
            height="320"
            loading="lazy"
            class="advisor-photo"
          />
        </div>
        <div class="advisor-info">
          <h3 class="advisor-name">Cherlynn Pearson</h3>
          <p class="advisor-title-label">Jordan Credit Union Medicare Advisor<br><em>Licensed Insurance Agent</em></p>
          <p class="advisor-bio">{CHERLYNN_BIO}</p>
          <dl class="advisor-contact">
            <div class="contact-row">
              <dt>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.6a16 16 0 0 0 6.08 6.08l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="sr-only">Phone</span>
              </dt>
              <dd><a href={`tel:${CHERLYNN_PHONE_TEL}`}>{CHERLYNN_PHONE}</a></dd>
            </div>
            <div class="contact-row">
              <dt>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span class="sr-only">Email</span>
              </dt>
              <dd><a href={`mailto:${CHERLYNN_EMAIL}`}>{CHERLYNN_EMAIL}</a></dd>
            </div>
            <div class="contact-row">
              <dt>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><path d="M12 12v4"/></svg>
                <span class="sr-only">Agency</span>
              </dt>
              <dd>A&amp;B Health Advocates</dd>
            </div>
          </dl>
          <a href="#consultation" class="btn btn-primary">Schedule a Free Consultation</a>

          <div class="advisor-agency">
            <img
              src="/images/ab-health-advocates-logo.png"
              alt="A&B Health Advocates — Helping with your healthcare needs"
              width="180"
              height="60"
              loading="lazy"
              class="agency-logo"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       4. HOW IT WORKS
  ══════════════════════════════════════════════════════════ -->
  <section class="how-it-works bg-light section-pad" aria-labelledby="steps-heading">
    <div class="container">
      <div class="section-header centered">
        <span class="section-eyebrow">Simple steps</span>
        <h2 id="steps-heading" class="section-title">How it works</h2>
        <p class="section-subtitle">Getting the right Medicare coverage is easier than you think when you have a trusted advisor at your side.</p>
      </div>
      <ol class="steps-list" role="list">
        <li class="step">
          <div class="step-num" aria-hidden="true">1</div>
          <div class="step-body">
            <h3 class="step-title">Reach out</h3>
            <p>Call, email, or complete the consultation form below. There's no paperwork to prepare — just show up.</p>
          </div>
        </li>
        <li class="step">
          <div class="step-num" aria-hidden="true">2</div>
          <div class="step-body">
            <h3 class="step-title">Talk it through</h3>
            <p>Cherlynn reviews your situation — your doctors, medications, budget, and enrollment timing — to understand what you need.</p>
          </div>
        </li>
        <li class="step">
          <div class="step-num" aria-hidden="true">3</div>
          <div class="step-body">
            <h3 class="step-title">Compare your options</h3>
            <p>Understand Original Medicare vs. Medicare Advantage, prescription drug plans, and supplement coverage — in plain language, side by side.</p>
          </div>
        </li>
        <li class="step">
          <div class="step-num" aria-hidden="true">4</div>
          <div class="step-body">
            <h3 class="step-title">Enroll with confidence</h3>
            <p>Cherlynn walks you through the application so you're enrolled correctly and on time. No missed deadlines, no late penalties.</p>
          </div>
        </li>
        <li class="step">
          <div class="step-num" aria-hidden="true">5</div>
          <div class="step-body">
            <h3 class="step-title">Ongoing support</h3>
            <p>Questions after enrollment? Your advisor is still here for you — during Annual Enrollment and anytime your situation changes.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       5. UNDERSTAND YOUR OPTIONS
  ══════════════════════════════════════════════════════════ -->
  <section class="options section-pad bg-white" aria-labelledby="options-heading">
    <div class="container">
      <div class="section-header centered">
        <span class="section-eyebrow">Your Medicare options</span>
        <h2 id="options-heading" class="section-title">Understanding the parts of Medicare</h2>
        <p class="section-subtitle">Medicare has several parts — each covering different services. Here's a plain-language overview.</p>
      </div>
      <div class="options-grid">
        <article class="option-card">
          <div class="option-badge">Part A &amp; B</div>
          <h3 class="option-title">Original Medicare</h3>
          <p>
            The foundation of Medicare coverage, provided directly by the federal government.
            <strong>Part A</strong> covers hospital stays, skilled nursing, and some home health care.
            <strong>Part B</strong> covers doctor visits, outpatient services, and preventive care.
            Both may include deductibles, copays, and coinsurance.
          </p>
        </article>
        <article class="option-card">
          <div class="option-badge option-badge--orange">Part C</div>
          <h3 class="option-title">Medicare Advantage</h3>
          <p>
            A private-plan alternative that covers everything Parts A and B do, often with lower
            out-of-pocket costs. Many plans bundle in prescription drug, dental, vision, and hearing
            coverage. Plans vary by network and region.
          </p>
        </article>
        <article class="option-card">
          <div class="option-badge">Part D</div>
          <h3 class="option-title">Prescription Drug Coverage</h3>
          <p>
            Helps pay for prescription medications. Part D plans are available as standalone plans
            (to pair with Original Medicare) or built into most Medicare Advantage plans.
            Formularies and costs vary by plan.
          </p>
        </article>
        <article class="option-card">
          <div class="option-badge option-badge--orange">Medigap</div>
          <h3 class="option-title">Medicare Supplement</h3>
          <p>
            Optional supplemental coverage sold by private insurers that helps pay the out-of-pocket
            costs Original Medicare doesn't cover — like deductibles, copays, and coinsurance.
            Cannot be combined with Medicare Advantage.
          </p>
        </article>
      </div>
      <p class="options-note">
        Not sure which path is right for you?
        <a href="#consultation">Talk to Cherlynn — it's free.</a>
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       6. TIMING & ENROLLMENT
  ══════════════════════════════════════════════════════════ -->
  <section class="timing bg-green section-pad" aria-labelledby="timing-heading">
    <div class="container timing-inner">
      <div class="timing-content">
        <span class="section-eyebrow" style="color: rgba(255,255,255,0.7)">Don't miss your window</span>
        <h2 id="timing-heading" class="section-title section-title--white">Medicare enrollment timing matters</h2>
        <div class="timing-body">
          <p>
            Your <strong>Initial Enrollment Period (IEP)</strong> is the 7-month window surrounding
            your 65th birthday — three months before, the month of, and three months after.
            Enrolling on time helps you avoid late-enrollment penalties that can follow you for life.
          </p>
          <p>
            There's also an <strong>Annual Enrollment Period</strong> (October 15 – December 7)
            when anyone on Medicare can switch or adjust plans.
          </p>
          <p class="timing-tip">
            <strong>Start early.</strong> Cherlynn recommends beginning the conversation at least
            three months before your 65th birthday so you have time to compare options without rushing.
          </p>
        </div>
        <a href="#consultation" class="btn btn-primary">Talk to Cherlynn About Timing</a>
      </div>
      <div class="timing-visual" aria-hidden="true">
        <div class="timeline">
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-label">3 months before 65<sup>th</sup> birthday</div>
            <div class="tl-desc">IEP begins — earliest you can enroll</div>
          </div>
          <div class="tl-item tl-item--highlight">
            <div class="tl-dot tl-dot--highlight"></div>
            <div class="tl-label">Your 65<sup>th</sup> birthday month</div>
            <div class="tl-desc">Coverage can start this month</div>
          </div>
          <div class="tl-item">
            <div class="tl-dot"></div>
            <div class="tl-label">3 months after 65<sup>th</sup> birthday</div>
            <div class="tl-desc">IEP closes — act before this date</div>
          </div>
          <div class="tl-item">
            <div class="tl-dot tl-dot--orange"></div>
            <div class="tl-label">Oct 15 – Dec 7 (annual)</div>
            <div class="tl-desc">Annual Enrollment Period — switch plans</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       7. FAQ
  ══════════════════════════════════════════════════════════ -->
  <section class="faq section-pad bg-light" aria-labelledby="faq-heading">
    <div class="container faq-wrap">
      <div class="section-header centered">
        <span class="section-eyebrow">Common questions</span>
        <h2 id="faq-heading" class="section-title">Frequently asked questions</h2>
      </div>
      <dl class="faq-list">
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-1">
              Is this really free?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-1" class="faq-a" hidden>
            Yes — completely free. Cherlynn is compensated by the insurance carriers when you enroll in a plan,
            which means you never pay for her guidance. There's no fee for consultations, comparisons, or help with enrollment.
          </dd>
        </div>
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-2">
              Do I have to be a JCU member to use this service?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-2" class="faq-a" hidden>
            This service is primarily offered as a free benefit for Jordan Credit Union members and their families.
            Contact Cherlynn to discuss your situation.
          </dd>
        </div>
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-3">
              What should I bring to my consultation?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-3" class="faq-a" hidden>
            It helps to have: a list of your current medications (name and dosage), your doctors' names and locations,
            your Medicare card or Social Security number, and a general sense of your monthly budget.
            Don't stress if you don't have everything — Cherlynn can help fill in the gaps.
          </dd>
        </div>
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-4">
              I'm already on Medicare. Can you still help me?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-4" class="faq-a" hidden>
            Absolutely. During the Annual Enrollment Period (October 15 – December 7) you can review your current
            plan, compare alternatives, and switch if there's a better fit. Cherlynn can also help if your
            circumstances have changed — new prescriptions, new doctors, or a move.
          </dd>
        </div>
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-5">
              Which plans do you offer?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-5" class="faq-a" hidden>
            Cherlynn is licensed to offer plans from several carriers in your area. Please note: we do not offer
            every plan available — see the disclaimer at the bottom of this page. For a complete view of all available
            options, visit <a href="https://www.medicare.gov" target="_blank" rel="noopener noreferrer">Medicare.gov</a>
            or call 1-800-MEDICARE.
          </dd>
        </div>
        <div class="faq-item">
          <dt>
            <button class="faq-q" aria-expanded="false" aria-controls="faq-6">
              My spouse is turning 65 soon too. Can we meet together?
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </dt>
          <dd id="faq-6" class="faq-a" hidden>
            Yes. Cherlynn often meets with couples together since your coverage decisions can affect each other — especially
            around shared doctors and prescription plans. Just mention it when you schedule.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       8. CONSULTATION CTA + CONTACT FORM
  ══════════════════════════════════════════════════════════ -->
  <section class="consultation section-pad bg-white" id="consultation" aria-labelledby="form-heading">
    <div class="container">
      <div class="section-header centered">
        <span class="section-eyebrow">Get started today</span>
        <h2 id="form-heading" class="section-title">Request your free, no-obligation Medicare consultation</h2>
        <p class="section-subtitle">
          Fill out the form and Cherlynn will be in touch within one business day. Prefer a quicker connection?
        </p>
        <div class="direct-contact">
          <a href={`tel:${CHERLYNN_PHONE_TEL}`} class="direct-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.6a16 16 0 0 0 6.08 6.08l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call: {CHERLYNN_PHONE}
          </a>
          <span class="direct-sep" aria-hidden="true">or</span>
          <a href={`mailto:${CHERLYNN_EMAIL}`} class="direct-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email Cherlynn
          </a>
        </div>
      </div>

      <!-- TODO: Replace [[FORM_ENDPOINT]] with your actual form handler URL before launch.
           Options: Formspree, JCU's CRM webhook, a backend API route, or a WordPress CF7 endpoint. -->
      <form
        id="medicare-form"
        class="consult-form"
        action={FORM_ENDPOINT}
        method="POST"
        novalidate
        aria-label="Medicare consultation request form"
      >
        <input type="hidden" name="form_type" value="medicare_consultation" />
        <input type="hidden" name="_subject" value="Medicare Consultation Request — JCU" />

        <div class="form-row">
          <div class="form-group">
            <label for="first_name">First name <span class="req" aria-hidden="true">*</span></label>
