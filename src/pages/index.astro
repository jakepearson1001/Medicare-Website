---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Homepage | Jordan Credit Union"
  description="Jordan Credit Union — serving Utah members since 1950. Free checking, low loan rates, and great savings rates."
>
  <section style="padding: 6rem 1.5rem; text-align: center; background: var(--jcu-gray-light); min-height: 60vh; display: flex; align-items: center; justify-content: center;">
    <div>
      <h1 style="font-size: 2rem; color: var(--jcu-green); margin-bottom: 1rem;">Jordan Credit Union</h1>
      <p style="color: var(--jcu-gray-text); max-width: 500px; margin: 0 auto 2rem;">
        This is a placeholder homepage. The full site lives at
        <a href="https://jordan-cu.org">jordan-cu.org</a>.
        The new Medicare page is available at
        <a href="/medicare/">/medicare/</a>.
      </p>
      <a href="/medicare/" class="btn btn-primary">View Medicare Page</a>
    </div>
  </section>
</BaseLayout>
