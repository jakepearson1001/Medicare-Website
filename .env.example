# Copy this file to .env.local (for `vercel dev`) or set these in your host's
# environment variables. The key is used ONLY by the serverless function in
# /api/analyze-food.js and is never exposed to the browser.

# Your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the vision model (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8
